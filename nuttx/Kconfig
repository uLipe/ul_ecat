# Include from apps/Kconfig, e.g.:
#   source "/path/to/ul_ecat/nuttx/Kconfig"

config UL_ECAT
	bool "ul_ecat EtherCAT libraries (master and/or slave)"
	default n
	help
	  EtherCAT master (raw L2) and/or slave ESC + LAN9252 SPI stack.

config UL_ECAT_MASTER
	bool "EtherCAT master core (scan, queue, DC)"
	default n
	depends on UL_ECAT && NET
	select NET_PKT
	help
	  Raw packet (AF_PACKET) path for EtherCAT ethertype 0x88A4.
	  Requires CONFIG_NET_PKT (packet sockets); see doc/nuttx-module.md for defconfig hints.

config UL_ECAT_SLAVE
	bool "EtherCAT slave + LAN9252 (SPI)"
	default n
	depends on UL_ECAT
	select SPI
	help
	  ESC mirror, PDU handling, LAN9252 driver + NuttX SPI HAL (ports/lan9252/nuttx/hal_nuttx.c).
	  Enable your board SPI driver (e.g. CONFIG_STM32_SPI1 / SPI0) in defconfig.
