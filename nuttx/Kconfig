# Include from apps/Kconfig, e.g.:
#   source "/path/to/ul_ecat/nuttx/Kconfig"

config UL_ECAT
	bool "ul_ecat EtherCAT master (library)"
	default n
	depends on NET
	help
	  Minimal EtherCAT master stack: frames, AL, scan, DC hooks.
	  Packet sockets may see other L2 traffic on the same interface; see doc/nuttx-module.md.

if UL_ECAT

config UL_ECAT_MASTER
	bool "EtherCAT master core (scan, queue, DC)"
	default n
	depends on UL_ECAT
	select NET_PKT
	help
	  Raw packet (AF_PACKET) path for EtherCAT ethertype 0x88A4.
	  Requires CONFIG_NET_PKT (packet sockets); see doc/nuttx-module.md for defconfig hints.

endif # UL_ECAT
