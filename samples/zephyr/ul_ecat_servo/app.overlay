/*
 * Template: point /chosen ul-ecat-spi at your LAN9252 SPI device node.
 * Adjust &spi0 / cs-gpios / pins to match your board; see README.
 */

/ {
	chosen {
		ul-ecat-spi = &lan9252;
	};
};

/* Example: enable SPI0 with one CS — replace with your SoC block */
&spi0 {
	status = "okay";
	cs-gpios = <&gpioa 4 GPIO_ACTIVE_LOW>;

	lan9252: lan9252@0 {
		compatible = "vnd,spi-device";
		reg = <0>;
		spi-max-frequency = <20000000>;
	};
};
