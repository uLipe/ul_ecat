config UL_ECAT
	bool "ul_ecat EtherCAT libraries"
	help
	  Minimal EtherCAT master and/or slave stacks. Enable UL_ECAT_MASTER
	  for L2 master (needs networking) and/or UL_ECAT_SLAVE for ESC + LAN9252.

if UL_ECAT

config UL_ECAT_MASTER
	bool "EtherCAT master (scan, queue, DC)"
	depends on NETWORKING
	select NET_SOCKETS
	select NET_SOCKETS_PACKET
	imply NET_IPV4
	imply NET_IPV6
	imply NET_SOCKETS_POSIX_NAMES
	help
	  Requires CONFIG_NET_SOCKETS_PACKET for raw EtherCAT (ethertype 0x88A4).

config UL_ECAT_TRANSPORT_NETDEV
	bool "TX frames via net_if (net_pkt) instead of socket send"
	depends on UL_ECAT_MASTER
	help
	  Sends built Ethernet frames with net_if_queue_tx() for direct driver TX.
	  RX and timing still use the packet socket on the same interface.

config UL_ECAT_SLAVE
	bool "EtherCAT slave (ESC mirror, PDU, LAN9252 controller)"
	select SPI
	help
	  Software ESC mirror, datagram handling, and optional LAN9252 SPI backend.

config UL_ECAT_LAN9252_HAL
	bool "LAN9252 Zephyr SPI HAL (/chosen ul-ecat-spi, SYS_INIT)"
	depends on UL_ECAT_SLAVE
	default y
	select SPI
	help
	  Strong HAL using devicetree /chosen ul-ecat-spi -> SPI device node.
	  Requires GPIO CS on the SPI node; CS is driven manually for LAN9252
	  register sequences. Enables CONFIG_SPI.

endif # UL_ECAT
